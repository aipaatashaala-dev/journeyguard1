<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_journeyguard_logo"
            android:contentDescription="@string/logo_desc"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tagline"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingBottom="20dp"/>

        <!-- Status Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/card_dark"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/serviceStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/service_stopped"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingBottom="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mobile_protection_summary"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:alpha="0.82" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartProtection"
            style="?attr/materialButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_start_protection"
            android:textSize="15sp"
            android:backgroundTint="@color/secondary"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopProtection"
            style="?attr/materialButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/btn_stop_protection"
            android:textSize="15sp"
            android:backgroundTint="@color/danger_red"
            android:layout_marginBottom="20dp"/>

        <!-- IMEI Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/card_dark"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/imeiText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📱 IMEI: Not set"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:selectable="true"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device verification for future recovery"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:alpha="0.7"
                    android:paddingTop="6dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- User Profile Details Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/card_dark"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/userDetailsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👤 Account Details"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:selectable="true"
                    android:typeface="monospace"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Speed card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/card_dark"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/speed_label"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingBottom="6dp"/>

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 km/h"
                    android:textSize="14sp"
                    android:textColor="@color/white"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Support -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSupport"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/support_button"/>

    </LinearLayout>
</ScrollView>
