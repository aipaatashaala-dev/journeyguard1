<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_journeyguard_logo"
            android:contentDescription="@string/logo_desc"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/register_button"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/register_username"
            android:inputType="textPersonName"
            android:backgroundTint="@color/white"
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/register_password"
            android:inputType="textPassword"
            android:backgroundTint="@color/white"
            android:textColor="@color/white" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Mobile Number"
            android:inputType="phone"
            android:backgroundTint="@color/white"
            android:textColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etIMEI"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter IMEI (15 digits)"
                android:inputType="number"
                android:maxLength="15"
                android:backgroundTint="@color/white"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnIMEIInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="ℹ️"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:textSize="18sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvIMEIGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="📱 How to get IMEI:\n1. Open Phone Dialer\n2. Dial: *#06#\n3. Your 15-digit IMEI will appear\n\n💡 Why? If you lose your phone, we can help verify device ownership."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@android:color/darker_gray"
            android:padding="8dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegisterConfirm"
            style="?attr/materialButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/register_button" />

    </LinearLayout>
</ScrollView>