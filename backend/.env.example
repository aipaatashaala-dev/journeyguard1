# ── Firebase ──────────────────────────────────────────────────
# Firebase service account JSON as full text (preferred for containerized deployments).
# Set as JSON text directly, or base64-encoded JSON.
FIREBASE_CREDENTIALS_JSON=

# Fallback path when credentials are on disk (local dev based flow)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Realtime DB URL (adjust for your project)
FIREBASE_DATABASE_URL=https://journeyguard-default-rtdb.firebaseio.com/

# ── Email (Gmail App Password recommended) ─────────────────────
EMAIL_HOST=smtp.zoho.in
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-smtp-app-password
EMAIL_FROM=JourneyGuard <your-email@example.com>

# ── App ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
LOCATION_TOKEN_SECRET=change-this-to-a-long-random-string
ADMIN_OTP_EMAIL=journeyguard@zohomail.in
ADMIN_OTP_SECRET=change-this-to-a-different-long-random-string

# ── Optional: Railway API ──────────────────────────────────────
# Get from https://railwayapi.site
RAILWAY_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
