# ── Firebase Web Config ───────────────────────────────────────
# Get from: Firebase Console → Project Settings → Web App
REACT_APP_FIREBASE_API_KEY=your_web_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=journeyguard.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=journeyguard
REACT_APP_FIREBASE_STORAGE_BUCKET=journeyguard.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:000000000000

# ── Backend API ────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
