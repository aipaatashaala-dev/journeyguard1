{
  "name": "journeyguard",
  "private": true,
  "scripts": {
    "web:install": "npm --prefix frontend install",
    "web:build": "npm --prefix frontend run build",
    "cap:sync": "npm run web:build && npx cap sync android",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npm run web:build && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^7.1.0",
    "@capacitor/core": "^7.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.1.0"
  }
}
